<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PocketAlbum.Studio.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="360"
        Width="500" Height="360" CanResize="False"
        xmlns:controls="clr-namespace:PocketAlbum.Studio.Views"
        x:Class="PocketAlbum.Studio.Views.ServerWindow"
        x:DataType="vm:ServerViewModel"
        Icon="/Assets/pocket_album_32.png"
        Title="Pair with remote album"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:ServerViewModel/>
    </Design.DataContext>

    <DockPanel>
        <DockPanel LastChildFill="True" Margin="20" DockPanel.Dock="Left" 
            Width="200">

            <TextBlock Text="Server" FontSize="20" 
                DockPanel.Dock="Top" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,10">
                <Button IsVisible="{Binding ServerRunning}" Click="StopServer">Stop</Button>
                <Button IsVisible="{Binding !ServerRunning}" Click="StartServer">Start</Button>
                <TextBlock FontSize="14" Margin="6,0" VerticalAlignment="Center" 
                    Text="{Binding ServerStatus}" />
            </StackPanel>
            <TextBlock FontSize="14" DockPanel.Dock="Top" Margin="0,6">
                Connected clients:
            </TextBlock>
            <ListBox ItemsSource="{Binding Clients}"></ListBox> 

        </DockPanel>
        <Separator DockPanel.Dock="Left" Height="NaN" Width="1" Margin="0,20"/>
        <DockPanel LastChildFill="True" Margin="20" DockPanel.Dock="Left">
            <TextBlock DockPanel.Dock="Top" FontSize="20"
                Text="Connect new client"/>

            <TextBlock Text="Scan the QR code with Pocket Album mobile app:" 
                DockPanel.Dock="Top" Margin="0,10" TextWrapping="Wrap"
                IsVisible="{Binding ServerRunning}" />
                
            <Image Width="240"
                Height="240"
                Source="{Binding ServerInfoQr}"
                DockPanel.Dock="Top"
                IsVisible="{Binding ServerRunning}" />

            <TextBlock Text="Server must be running for clients to connect." 
                Margin="0,10" TextWrapping="Wrap"
                IsVisible="{Binding !ServerRunning}" />

        </DockPanel>
    </DockPanel>
</Window>
